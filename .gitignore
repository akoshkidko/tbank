# В репозиторий не попадает ничего, кроме каталога docs/ (только нужные файлы) и workflow Pages.
/*
!/.gitignore
!/docs/
!/.github/
!/support-automation-roadmap-visual.md
!/support-automation-gantt-roles.md

/.github/*
!/.github/workflows/
/.github/workflows/*
!/.github/workflows/pages.yml

/docs/*
!/docs/prototype.html
!/docs/support-automation-roadmap-visual.html
!/docs/gantt-roles.html
!/docs/.nojekyll
